# ============================================
# UPSKILLIZE AI AGENT (Python + FastAPI)
# ============================================
# Copy this file as .env and fill in your values

PORT=7860

# AI Provider: "huggingface" (FREE) or "anthropic" (PAID)
AI_PROVIDER=huggingface

# Hugging Face — Get from: https://huggingface.co/settings/tokens
HF_ACCESS_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude — Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MySQL Database (Avian Cloud) — Paste your DATABASE_URL
DATABASE_URL=mysql://user:pass@host:3306/dbname

# Security — Generate: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_API_KEY=paste-your-generated-key-here

# Your URLs
MAIN_BACKEND_URL=https://upskillize-lms-backend.onrender.com/api
FRONTEND_URL=https://lms.upskillize.com
